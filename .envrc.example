use_nvm() {
  local node_version=$1
  nvm_sh=$([ -s "$NVM_DIR/nvm.sh" ] && echo "$NVM_DIR/nvm.sh")
  if [ -n "$nvm_sh" ]; then
    source "$nvm_sh"
    nvm use "$node_version"
  fi
}

use_nvm 24

# Backend (signaling-server) — all have defaults, override as needed
# export SERVER_ADDRESS=localhost
# export SERVER_PORT=8080
# export ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://ryandur.github.io
# export LOG_LEVEL=INFO

# Frontend (web-client) — Vite build-time env vars
# export VITE_SERVICE_URL=http://localhost:8080
